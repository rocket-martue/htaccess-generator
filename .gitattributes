# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Explicitly LF for web assets
*.html text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binary — do not modify
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
